# Supabase browser configuration (public anon key only; never use service-role keys in Vite)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Application Configuration
VITE_APP_NAME=BizGuard
VITE_APP_VERSION=1.0.0
VITE_APP_URL=http://localhost:5173

# AI should be called through a server-side endpoint/Supabase Edge Function.
# Do NOT put OPENAI_API_KEY in Vite frontend env variables.
VITE_AI_ENDPOINT=

# Public payment keys only; secret keys belong on the server/Edge Functions.
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_PAYSTACK_PUBLIC_KEY=
VITE_FLUTTERWAVE_PUBLIC_KEY=

# Feature Flags
VITE_ENABLE_PHASE_1=true
VITE_ENABLE_PHASE_2=true
VITE_ENABLE_PHASE_3=true
VITE_ENABLE_PHASE_4=false
VITE_ENABLE_PHASE_5=false
